# ---------- Entra ID / Microsoft Graph ----------
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_SECRET=replace-me

# Comma-separated list of subscription IDs to roll up for Foundry / Azure metrics.
# Leave blank to auto-discover all subscriptions the SP can see.
AZURE_SUBSCRIPTION_IDS=

# ---------- Azure OpenAI (powers the LangGraph agent) ----------
AZURE_OPENAI_ENDPOINT=https://your-aoai-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=replace-me
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21

# ---------- Agent behavior ----------
USE_MOCK_DATA=true
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173

# ---------- MCP server endpoints (defaults point to local stdio) ----------
WORKIQ_MCP_CMD=python -m backend.mcp_servers.workiq_server
FOUNDRYIQ_MCP_CMD=python -m backend.mcp_servers.foundryiq_server
COPILOT_STUDIO_MCP_CMD=python -m backend.mcp_servers.copilot_studio_server
